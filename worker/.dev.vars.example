# Copy to `.dev.vars` (gitignored) and fill in for `wrangler dev`.
# Axiom ingest token — the Worker POSTs click events to the AXIOM_DATASET
# configured in wrangler.toml. Without it, redirects still work; events 401
# silently (fire-and-forget).
AXIOM_TOKEN=your-axiom-ingest-token

# Worker->origin shared secret for the internal /resolve call. Must match the
# Django origin's SHARED_SECRET (its dev default is "dev-shared-secret").
SHARED_SECRET=dev-shared-secret
