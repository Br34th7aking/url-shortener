# Copy to .env and fill in. .env is gitignored.

# Which settings module to load (config.settings.dev | config.settings.prod)
DJANGO_SETTINGS_MODULE=config.settings.dev

# Generate one for real use:  python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me

DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Leave unset for the sqlite fallback (bare local run).
# In Docker this is set to Postgres, e.g.:
# DATABASE_URL=postgres://urlshort:urlshort@db:5432/urlshort

# Leave unset for the locmem fallback. In Docker:
# REDIS_URL=redis://redis:6379/0
